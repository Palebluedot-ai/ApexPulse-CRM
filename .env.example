DATABASE_URL=postgres://postgres:postgres@localhost:5432/hashkey_otc_crm_v1
# Mac mini 自托管公网暴露时必改：写入 .env（docker compose 自动读取，不进 Git），
# 并同步修改上面 DATABASE_URL 里的密码。
POSTGRES_PASSWORD=
# 可选。Supabase migration 建议使用单独 direct/session 连接；为空时回退到 DATABASE_URL。
MIGRATION_DATABASE_URL=
# Supabase pooler runtime 建议 false；本地 direct Postgres 可以 true。
DATABASE_PREPARE=true

# 第一版仍使用本项目自己的本地账号登录。
# 云端 staging / production 也先沿用这组变量，不在 M1.23 切 Supabase Auth。
LOCAL_AUTH_EMAIL=chao.local@example.com
LOCAL_AUTH_PASSWORD=local-dev-password
AUTH_SESSION_SECRET=replace-with-a-long-local-random-string
AUTH_STRICT_ENV=false
AUTH_COOKIE_SECURE=false

# M1.18 外部视觉 API。真实 key 只写入本机 .env.local，不提交到 Git。
VISION_API_PROVIDER=openai-compatible
VISION_API_KEY=
VISION_API_BASE_URL=https://api.openai.com/v1
VISION_API_MODEL=

# M1.23 云端部署。local 开发可以暂时不填。
# Vercel 上不能长期保存上传文件，所以 staging / production 必须使用 Supabase Storage。
STORAGE_PROVIDER=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=otc-crm-attachments
APP_BASE_URL=http://localhost:3000
